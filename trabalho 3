import mysql.connector
from mysql.connector import Error

def conectar():
    try:
        conexao = mysql.connector.connect(
            host='localhost',
            user='root',
            password='root',
            database='projeto_vendas_eletronicos_unifecaf'
        )

        if conexao.is_connected():
            print("Conectado ao MySQL com sucesso!")
            return conexao

    except Error as e:
        print(f"Erro ao conectar: {e}")
        return None


import mysql.conectar
def total_vendas_periodo():
    data_inicio = input("Coloque a primeira data do periodo desejado: ")
    data_fim = input("Coloque o ultimo data do periodo desejado: ")
    conexao = mysql.conectar.connect(host="localhost", user="root", password="", database="projeto_vendas_eletronicos_unifecaf")
    cursor = conexao.cursor()
    comando = f"SELECT SUM(valor_final) FROM vendas WHERE data_e_hora BETWEEN '{data_inicio} 00:00:00' AND '{data_fim} 23:59:59'"
    cursor.execute(comando)
    resultado = cursor.fetchone()[0]
    cursor.close()
    conexao.close()

    if resultado is None:
        resultado = 0.0
    return f'valor vendido no período: R$ {resultado:.2f}'


def qtd_vendas_por_vendedor():
    conexao = mysql.conectar.connect(host="localhost", user="root", password="", database="projeto_vendas_eletronicos_unifecaf")
    cursor = conexao.cursor()
    comando = "SELECT id_vendedor, COUNT(id) FROM vendas GROUP BY id_vendedor"
    cursor.execute(comando)
    resultados = cursor.fetchall()
    cursor.close()
    conexao.close()

    print("\n--- quantidade de vendas por ID do Vendedor ---")
    for linha in resultados:
        print(f'ID {linha[0]}: {linha[1]} venda(s)')
    return ""


def ticket_medio_geral():
    conexao = mysql.conectar.connect(host="localhost", user="root", password="", database="projeto_vendas_eletronicos_unifecaf")
    cursor = conexao.cursor()
    comando = "SELECT AVG(valor_final) FROM vendas"
    cursor.execute(comando)
    resultado = cursor.fetchone()

    cursor.close()
    conexao.close()

    if resultado is None:
        resultado = 0.0

    return f"ticket medio geral: R$ {resultado:.2f}"


def ticket_medio_por_vendedor():
    conexao = mysql.connector.connect(host="localhost", user="root", password="", database="projeto_vendas_eletronicos_unifecaf")
    cursor = conexao.cursor()
    comando = '''
        SELECT vendedores.nome, AVG(vendas.valor_final) 
        FROM vendas 
        INNER JOIN vendedores ON vendas.id_vendedor = vendedores.id 
        GROUP BY vendedores.nome
    '''
    cursor.execute(comando)
    resultados = cursor.fetchall()
    cursor.close()
    conexao.close()

    print("\n--- Ticket médio por vendedor ---")
    for linha in resultados:
        print(f"Vendedor: {linha[0]} Média: R$ {linha[1]:.2f}")
    return ""


def produto_mais_vendido_qtd():
    conexao = mysql.connector.connect(host="localhost", user="root", password="", database="projeto_vendas_eletronicos_unifecaf")
    cursor = conexao.cursor()
    comando = """
        SELECT produtos.descricao, SUM(vendas_produtos.quantidade) AS total
        FROM vendas_produtos
        INNER JOIN produtos ON vendas_produtos.id_produto = produtos.id
        GROUP BY produtos.descricao
        ORDER BY total DESC
        LIMIT 1
    """
    cursor.execute(comando)
    resultado = cursor.fetchone()

    cursor.close()
    conexao.close()

    if resultado:
        return f"produto mais vendido: {resultado[0]} ({resultado[1]})"
    return "Nenhum produto vendido."


def produto_mais_rentavel_valor():
    conexao = mysql.connector.connect(host="localhost", user="root", password="", database="projeto_vendas_eletronicos_unifecaf")
    cursor = conexao.cursor()
    comando = '''
        SELECT produtos.descricao, SUM(vendas_produtos.valor_total) AS faturamento
        FROM vendas_produtos
        INNER JOIN produtos ON vendas_produtos.id_produto = produtos.id
        GROUP BY produtos.descricao
        ORDER BY faturamento DESC
        LIMIT 1
    '''
    cursor.execute(comando)
    resultado = cursor.fetchone()
    cursor.close()
    conexao.close()

    if resultado:
        return f'produto mais rentável: {resultado[0]} (fatura: R$ {resultado[1]:.2f})'
    return 'Nenhum produto vendido'


